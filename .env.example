# ─── App ─────────────────────────────────────────────────────────────────────
# URL where the app is running (no trailing slash)
NEXTAUTH_URL=http://localhost:3000

# Generate a strong random secret:  openssl rand -base64 32
NEXTAUTH_SECRET=your-strong-random-secret-here

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_DATABASE=tender_trakr

# ─── AI (Google Gemini) ───────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ─── Tender247 Credentials ────────────────────────────────────────────────────
# These are also editable from the Settings page in the UI
TENDER247_EMAIL=your-tender247-email@example.com
TENDER247_PASSWORD=your-tender247-password
